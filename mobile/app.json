{
  "expo": {
    "name": "PocketCA",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pocketca-logo.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/pocketca-logo.png"
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/pocketca-logo.png"
    },
    "splash": {
      "image": "./assets/images/pocketca-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B14"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0B14",
          "image": "./assets/images/pocketca-logo.png",
          "imageWidth": 150
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
